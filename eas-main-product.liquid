{
  "name": "EasyAIStack main product",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Blueprint Options"
    },
    {
      "type": "url",
      "id": "local_sample_url",
      "label": "Local service sample plan URL"
    },
    {
      "type": "url",
      "id": "agency_sample_url",
      "label": "Agency sample plan URL"
    }
  ]
}
{% endschema %}
